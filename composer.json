{
    "name": "vendor/comments-client",
    "description": "PHP HTTP-клиент для REST-сервиса комментариев example.com",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Vendor\\CommentsClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vendor\\CommentsClient\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
