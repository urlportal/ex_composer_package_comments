{
    "name": "vendor/comments-client",
    "description": "PHP HTTP-клиент для REST-сервиса комментариев example.com",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^10.5",
        "rector/rector": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Vendor\\CommentsClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vendor\\CommentsClient\\Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "8.1"
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "rector": "rector process --dry-run",
        "rector-fix": "rector process",
        "all": [
            "@test",
            "@stan",
            "@cs",
            "@rector"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
